# App Store Connect API key for unattended TestFlight uploads.
# Copy to deploy/.env (gitignored) and fill in. The .p8 lives in
# ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_.p8
